# Copy this file to .env (kept local, ignored by git), then fill values.
MQTT_HOST=your-cluster-id.s1.eu.hivemq.cloud
MQTT_PORT=8883
MQTT_CLIENT_ID=smarthome-backend
MQTT_USER=your-hivemq-username
MQTT_PASSWORD=your-hivemq-password

# Optional overrides
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=smarthome
# DB_USER=smarthome
# DB_PASSWORD=smarthome
# CORS_ORIGINS=http://localhost:4200
